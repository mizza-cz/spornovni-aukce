      <input type="hidden" name="category" value="1" />

      <div role="tablist" class="d-flex flex-wrap gap-4 filterMenu-categories">
        <button
          name="category"
          value="all"
          class="badge-primary-500 has-hover"
          role="tab"
          aria-selected="true"
        >
          Vše
          <span>48</span>
        </button>
        <button
          name="category"
          value="1"
          class="badge-gray-100 has-hover"
          role="tab"
