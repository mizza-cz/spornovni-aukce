          Fotbalové dresy
          <span>5</span>
        </button>
        <button
          name="category"
          value="3"
          class="badge-gray-100 has-hover"
          role="tab"
        >
          Hokejové dresy
          <span>4</span>
        </button>
        <button
          name="category"
          value="4"
          class="badge-gray-100 has-hover"
          role="tab"
