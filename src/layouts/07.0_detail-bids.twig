{% extends "@components/base/base.twig" %} {% set title = "07.0_detail-bids" %}
{% block main %} {% include "@components/header/header.twig" %}
<main id="main-content" class="main" aria-label="Hlavní obsah">
  <section class="container pt-14 pb-20">
    {% include "@components/detail-bids/detail-bids.twig" %} {% include
    "@components/auctionItems/auctionItems.twig" %}
    <div class="tableBids p-6 bg-gray-100 rounded-lg mb-14">
      <h3 class="h5 mb-4 fw-semibold">Příhozy</h3>
      <div class="table-responsive mb-6">
        <table class="auctionTable">
          <thead>
            <tr>
              <th class="auctionTable-btn d-lg-none"></th>
              <th class="text-start" data-sort="name" data-type="text">
                <a href="#">Název předmětu / dresu</a>
              </th>
              <th class="text-start" data-sort="price" data-type="price">
                <a href="#">Cena</a>
              </th>
              <th
                class="text-start d-lg-table-cell d-none"
                data-sort="time"
                data-type="datetime"
              >
                <a href="#">Čas</a>
              </th>
              <th class="text-start d-lg-table-cell d-none">
                <a href="#">Přihazující</a>
              </th>
              <th>Akce</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="auctionTable-btn d-lg-none">
                <button class="auctionHistory__btn">
                  <img
                    src="images/ico/chevron-dark.svg"
                    width="24"
                    height="24"
                    class="object-fit-contain"
                    alt=""
                  />
                </button>
              </td>
              <td>
                <div class="fw-semibold">
                  Aukce dresů ze sedmého ročníku projektu PIRÁTI CHOMUTOV PRO
                  NEMOCNICI
                </div>
              </td>
              <td class="fw-semibold item-price">1 500 Kč</td>
              <td class="text-gray-400 fw-medium d-lg-table-cell d-none">
                13:00:00 23.2.2021
              </td>
              <td class="fw-semibold d-lg-table-cell d-none">Petr F.</td>
              <td>
                <button
                  data-bs-toggle="modal"
                  data-bs-target="#bidsModal"
                  class="button-gray-800 button-sm"
                >
                  Přihodit
                </button>
              </td>
            </tr>
            <tr class="auction-history-details d-none">
              <td class="d-lg-none"></td>
              <td colspan="4" class="text-start">
                <div class="fw-semibold">Čas příhozu</div>
                <div class="fw-medium mt-1">13:00:00 23.2.2021</div>
              </td>
            </tr>

            <tr>
              <td class="auctionTable-btn d-lg-none">
                <button class="auctionHistory__btn">
                  <img
                    src="images/ico/chevron-dark.svg"
                    width="24"
                    height="24"
                    class="object-fit-contain"
                    alt=""
                  />
                </button>
              </td>
              <td>
                <div class="fw-semibold">
                  Benefiční aukce dresů z utkání Zlín Stars vs. Real Top Praha
                </div>
              </td>
              <td class="fw-semibold item-price">1 500 Kč</td>
              <td class="text-gray-400 fw-medium d-lg-table-cell d-none">
                11:00:00 23.2.2025
              </td>
              <td class="fw-semibold d-lg-table-cell d-none">Jarmil P.</td>
              <td>
                <button
                  data-bs-toggle="modal"
                  data-bs-target="#bidsModal"
                  class="button-gray-800 button-sm"
                >
                  Přihodit
                </button>
              </td>
            </tr>
            <tr class="auction-history-details d-none">
              <td class="d-lg-none"></td>
              <td colspan="4" class="text-start">
                <div class="fw-semibold">Čas příhozu</div>
                <div class="fw-medium mt-1">11:00:00 23.2.2025</div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
      <nav aria-label="Další stránky">
        <ul
          class="pagination d-flex flex-wrap pagination-flat pagination-success"
        >
          <li class="page-item page-item__prev disabled">
            <a data-abc="true" href="#" class="button-stroke">
              {% include "@images/chevron-left.svg" %} Zpět
            </a>
          </li>
          <li class="page-item active">
            <a class="page-link button-primary-500" href="#" data-abc="true"
              >1</a
            >
          </li>
          <li class="page-item">
            <a class="page-link button-stroke" href="#" data-abc="true">2</a>
          </li>
          <li class="page-item">
            <a class="page-link button-stroke" href="#" data-abc="true">3</a>
          </li>
          <li class="page-item">
            <a class="page-link button-stroke" href="#" data-abc="true">4</a>
          </li>
          <li class="page-item">
            <a class="page-link button-stroke" href="#" data-abc="true">5</a>
          </li>
          <li class="page-item">
            <a class="page-link button-stroke" href="#" data-abc="true">6</a>
          </li>
          <li class="page-item">
            <a class="page-link button-stroke" href="#" data-abc="true">7</a>
          </li>
          <li class="page-item">
            <a class="page-link button-stroke" href="#" data-abc="true">8</a>
          </li>
          <li class="page-item">
            <a class="page-link button-stroke" href="#" data-abc="true">9</a>
          </li>
          <li class="page-item">
            <a class="page-link button-stroke" href="#" data-abc="true">10</a>
          </li>
          <li class="page-item">
            <a class="page-link" href="#" data-abc="true">...</a>
          </li>
          <li class="page-item">
            <a class="page-link button-stroke" href="#" data-abc="true">24</a>
          </li>

          <li class="page-item page-item__next">
            <a class="button-stroke" href="#" data-abc="true">
              Další strana {% include "@images/chevron-right.svg" %}
            </a>
          </li>
        </ul>
      </nav>

      {% include "@components/modal/modal-bids.twig" %} {% include
      "@components/modal/modal-buyNow.twig" %}
    </div>
  </section>
  {% include "@components/reference-section/reference-section.twig" %}
</main>

{% endblock %}
